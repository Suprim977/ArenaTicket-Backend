# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/arenaticket

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Payment Gateways (Nepal)
ESEWA_SECRET_KEY=your_esewa_secret_key_here
ESEWA_MERCHANT_CODE=EPAYTEST
KHALTI_SECRET_KEY=your_khalti_secret_key_here
KHALTI_MERCHANT_CODE=your_khalti_merchant_code_here